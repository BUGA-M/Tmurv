{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tmurv",
  "version": "0.1.0",
  "identifier": "ma.buga.tmurv",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tmurv",
        "width": 400,
        "height": 610,
        "minWidth": 400,
        "minHeight": 610,
        "center": true,
        "resizable": true,
        "devtools": true,
        "focus": true,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": true,
        "backgroundColor": null
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": ["icons/128x128.png", "resources/sounds/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "BUGA-M",
    "copyright": "Copyright © 2026 Tmurv. All rights reserved.",
    "category": "Productivity",
    "shortDescription": "Sleek and secure Pomodoro timer.",
    "longDescription": "Tmurv is a modern, secure Pomodoro timer with custom audio alerts, background execution via the system tray, and strict data isolation.",
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": null
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false,
        "files": {}
      },
      "deb": {
        "files": {}
      },
      "rpm": {
        "epoch": 0,
        "files": {},
        "release": "1"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ5RjgyODZBNkY4Q0NGRDQKUldUVXo0eHZhaWo0MlV6LzNqVVVlS0l2VGFMNTFQRWRhblFGcS9TUFlISmFZNEVwTk0rcWlRTlkK",
      "endpoints": [
        "https://github.com/BUGA-M/Tmurv/releases/latest/download/latest.json"
      ]
    }
  }
}
